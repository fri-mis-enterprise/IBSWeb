@{
    ViewData["Title"] = "Batch ReJournal";
    var now = DateTimeHelper.GetCurrentPhilippineTime();
    var currentYear = now.Year;
    var currentMonth = now.Month;
}

<div class="container-fluid mt-4">
    <div class="bg-secondary p-3 rounded shadow mb-3">
        <h2 class="text-white m-0">@ViewData["Title"]</h2>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-4">
            <p class="text-muted mb-2">
                Rebuild posted general ledger entries in one run using this order:
                <strong>Purchase</strong>, <strong>Sales</strong>, <strong>Service</strong>, <strong>Collection</strong>, <strong>Provisional Receipt</strong>, <strong>Debit Memo</strong>, <strong>Credit Memo</strong>, <strong>Payment</strong>, and <strong>JV</strong>.
            </p>

            <div class="alert alert-warning mb-3" role="alert">
                <strong>Effect of this action:</strong> Existing posted general ledger entries for the selected month and year will be deleted and rebuilt.
                Purchase, Sales, Service, Collection, Provisional Receipt, Debit Memo, Credit Memo, Payment, and JV entries will be regenerated in sequence. This is intended for accounting correction and
                rejournal purposes only. Inventory and other operational records are not recreated by this batch action.
            </div>

            <form id="rejournalAllForm" asp-action="ReJournalAll" method="post">
                @Html.AntiForgeryToken()
                <div class="row align-items-end">
                    <div class="col-md-3">
                        <label for="rejournalMonth" class="form-label fw-bold">Month</label>
                        <input id="rejournalMonth" name="month" type="number" class="form-control" min="1" max="12" value="@currentMonth" required />
                    </div>
                    <div class="col-md-3">
                        <label for="rejournalYear" class="form-label fw-bold">Year</label>
                        <input id="rejournalYear" name="year" type="number" class="form-control" min="2000" max="2100" value="@currentYear" required />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-danger w-100">
                            <i class="bi bi-arrow-repeat"></i> Run Batch ReJournal
                        </button>
                    </div>
                </div>
            </form>

            <div id="rejournalResult" class="mt-3 d-none"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const form = document.getElementById("rejournalAllForm");
            const result = document.getElementById("rejournalResult");

            if (!form || !result) {
                return;
            }

            form.addEventListener("submit", async function (event) {
                event.preventDefault();

                const month = document.getElementById("rejournalMonth")?.value;
                const year = document.getElementById("rejournalYear")?.value;

                const confirmed = confirm(
                    `This will delete and rebuild posted general ledger entries for ${month}/${year} in this order:\n` +
                    `Purchase -> Sales -> Service -> Collection -> Provisional Receipt -> Debit Memo -> Credit Memo -> Payment -> JV.\n\n` +
                    `Inventory and other operational records will not be recreated by this batch action.\n\n` +
                    `Do you want to continue?`
                );

                if (!confirmed) {
                    return;
                }

                const submitButton = form.querySelector('button[type="submit"]');
                const originalText = submitButton.innerHTML;

                submitButton.disabled = true;
                submitButton.innerHTML = '<i class="bi bi-hourglass-split"></i> Processing...';
                result.className = "mt-3 d-none";
                result.innerHTML = "";

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: new FormData(form)
                    });

                    const data = await response.json();

                    if (!response.ok || data.success === false) {
                        throw new Error(data.error || "Batch rejournal failed.");
                    }

                    result.className = "alert alert-success mt-3";
                    result.innerHTML =
                        `<strong>Batch rejournal completed.</strong><br>` +
                        `Purchase: ${data.purchaseCount ?? 0}<br>` +
                        `Sales: ${data.salesCount ?? 0}<br>` +
                        `Service: ${data.serviceCount ?? 0}<br>` +
                        `Collection: ${data.collectionCount ?? 0}<br>` +
                        `Provisional Receipt: ${data.provisionalReceiptCount ?? 0}<br>` +
                        `Debit Memo: ${data.debitMemoCount ?? 0}<br>` +
                        `Credit Memo: ${data.creditMemoCount ?? 0}<br>` +
                        `Payment: ${data.paymentCount ?? 0}<br>` +
                        `JV: ${data.jvCount ?? 0}`;
                } catch (error) {
                    result.className = "alert alert-danger mt-3";
                    result.textContent = error.message || "Batch rejournal failed.";
                } finally {
                    submitButton.disabled = false;
                    submitButton.innerHTML = originalText;
                }
            });
        })();
    </script>
}
